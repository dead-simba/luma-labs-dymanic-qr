generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Link {
  id             String   @id @default(uuid())
  shortCode      String   @unique
  destinationUrl String
  scanCount      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([shortCode])
}
